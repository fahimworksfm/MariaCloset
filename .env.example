# Copy to .env.local and fill in. None are required to run the public site.

# Password for the /admin dashboard. CHANGE THIS before sharing the app.
ADMIN_PASSWORD=mariacloset

# Optional — enables "✨ Auto-fill from photo" in the admin (Groq vision).
# Get a key at https://console.groq.com
GROQ_API_KEY=
# Vision-capable Groq model id (see https://console.groq.com/docs/models → a
# Llama 4 model). Leave unset to use the built-in default (Llama 4 Scout).
GROQ_VISION_MODEL=

# Note: "Remove background" in the admin runs free in the browser
# (@imgly/background-removal) — no API key needed.
