# Copy to .env.local and fill in. None are required to run the public site.

# Password for the /admin dashboard. CHANGE THIS before sharing the app.
ADMIN_PASSWORD=mariacloset

# Optional — enables "✨ Auto-fill from photo" in the admin (Groq vision).
# Get a key at https://console.groq.com
GROQ_API_KEY=
# Vision-capable Groq model id (see https://console.groq.com/docs/models → a
# Llama 4 model). Leave unset to use the built-in default (Llama 4 Scout).
GROQ_VISION_MODEL=

# Storage for admin uploads + saved items + rent requests.
# On Vercel: create a Blob store (Project → Storage → Blob) and this token is
# injected automatically, so uploads/edits persist. Locally, leave it unset to
# use the filesystem (data/ + public/uploads/); only set it to test Blob locally.
BLOB_READ_WRITE_TOKEN=

# Optional — email notifications (new request → owner, approve/decline → renter).
# Get a key at https://resend.com. Without it, notifications are simply skipped.
RESEND_API_KEY=
# Verified sender (or leave default for Resend test mode, which only delivers to
# your own Resend account email).
RESEND_FROM="Maria's Closet <onboarding@resend.dev>"
# Where new-request emails go (defaults to siteConfig.ownerEmail if unset).
OWNER_EMAIL=

# Note: "Remove background" in the admin runs free in the browser
# (@imgly/background-removal) — no API key needed.
