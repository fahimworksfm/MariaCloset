# Copy to .env.local and fill in. None are required to run the public site.

# Password for the /admin dashboard. CHANGE THIS before sharing the app.
ADMIN_PASSWORD=mariacloset

# Optional — enables "✨ Auto-fill from photo" in the admin (Groq vision).
# Get a key at https://console.groq.com
GROQ_API_KEY=
# Vision-capable Groq model id (check https://console.groq.com/docs/models).
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Optional — enables background removal in the admin (remove.bg).
REMOVEBG_API_KEY=

# Optional — enables garment extraction in the admin (Replicate clothes-segmentation).
REPLICATE_API_TOKEN=
